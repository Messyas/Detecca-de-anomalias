<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_Monitor">
    <bpmn:participant id="Participant_Gestao" name="Gestão de Anomalias de Gravação" processRef="Process_ToBe_Monitor_V2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ToBe_Monitor_V2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Monitor" name="Monitor Automatizado">
        <bpmn:flowNodeRef>StartEvent_NovoLog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ingerir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Calcular</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Anomalia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Descartar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SemAcao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Severidade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirAlerta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GravarAuditoria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Auditoria</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HITL" name="Especialista de Linha (HITL)">
        <bpmn:flowNodeRef>Task_AvaliarContexto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Aprovar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Autorizar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarFalso</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_NovoLog" name="Receber Novo Log de Teste">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Ingerir" name="Ingerir Arquivo de Janela">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Calcular" name="Calcular Métricas Preditivas">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Anomalia" name="Detectou Anomalia Sistemática?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_NaoRuido</bpmn:outgoing>
      <bpmn:outgoing>Flow_SimAnomalia</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Task_Descartar" name="Descartar Ruído Isolado">
      <bpmn:incoming>Flow_NaoRuido</bpmn:incoming>
      <bpmn:outgoing>Flow_FimRuido</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:endEvent id="EndEvent_SemAcao" name="Processo Concluído sem Ação">
      <bpmn:incoming>Flow_FimRuido</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_Severidade" name="Qual a Severidade?">
      <bpmn:incoming>Flow_SimAnomalia</bpmn:incoming>
      <bpmn:outgoing>Flow_BaixaMedia</bpmn:outgoing>
      <bpmn:outgoing>Flow_AltaAmbiguo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_EmitirAlerta" name="Emitir Alerta e Sugerir Ação">
      <bpmn:incoming>Flow_BaixaMedia</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaAuditoria1</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_AvaliarContexto" name="Avaliar Contexto da Anomalia">
      <bpmn:incoming>Flow_AltaAmbiguo</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaAprovar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Aprovar" name="Aprovar Ação Sugerida?">
      <bpmn:incoming>Flow_ParaAprovar</bpmn:incoming>
      <bpmn:outgoing>Flow_SimHITL</bpmn:outgoing>
      <bpmn:outgoing>Flow_NaoHITL</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Autorizar" name="Autorizar Intervenção na Linha">
      <bpmn:incoming>Flow_SimHITL</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaAuditoria2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RegistrarFalso" name="Registrar Falso Positivo">
      <bpmn:incoming>Flow_NaoHITL</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaAuditoria3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GravarAuditoria" name="Gravar Trilha de Auditoria">
      <bpmn:incoming>Flow_ParaAuditoria1</bpmn:incoming>
      <bpmn:incoming>Flow_ParaAuditoria2</bpmn:incoming>
      <bpmn:incoming>Flow_ParaAuditoria3</bpmn:incoming>
      <bpmn:outgoing>Flow_FimFinal</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Auditoria" name="Trilha de Auditoria Gravada">
      <bpmn:incoming>Flow_FimFinal</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_NovoLog" targetRef="Task_Ingerir" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Ingerir" targetRef="Task_Calcular" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Calcular" targetRef="Gateway_Anomalia" />
    <bpmn:sequenceFlow id="Flow_NaoRuido" name="Não" sourceRef="Gateway_Anomalia" targetRef="Task_Descartar" />
    <bpmn:sequenceFlow id="Flow_FimRuido" sourceRef="Task_Descartar" targetRef="EndEvent_SemAcao" />
    <bpmn:sequenceFlow id="Flow_SimAnomalia" name="Sim" sourceRef="Gateway_Anomalia" targetRef="Gateway_Severidade" />
    <bpmn:sequenceFlow id="Flow_BaixaMedia" name="Baixa / Média" sourceRef="Gateway_Severidade" targetRef="Task_EmitirAlerta" />
    <bpmn:sequenceFlow id="Flow_AltaAmbiguo" name="Alta / Ambígua" sourceRef="Gateway_Severidade" targetRef="Task_AvaliarContexto" />
    <bpmn:sequenceFlow id="Flow_ParaAprovar" sourceRef="Task_AvaliarContexto" targetRef="Gateway_Aprovar" />
    <bpmn:sequenceFlow id="Flow_SimHITL" name="Sim" sourceRef="Gateway_Aprovar" targetRef="Task_Autorizar" />
    <bpmn:sequenceFlow id="Flow_NaoHITL" name="Não" sourceRef="Gateway_Aprovar" targetRef="Task_RegistrarFalso" />
    <bpmn:sequenceFlow id="Flow_ParaAuditoria1" sourceRef="Task_EmitirAlerta" targetRef="Task_GravarAuditoria" />
    <bpmn:sequenceFlow id="Flow_ParaAuditoria2" sourceRef="Task_Autorizar" targetRef="Task_GravarAuditoria" />
    <bpmn:sequenceFlow id="Flow_ParaAuditoria3" sourceRef="Task_RegistrarFalso" targetRef="Task_GravarAuditoria" />
    <bpmn:sequenceFlow id="Flow_FimFinal" sourceRef="Task_GravarAuditoria" targetRef="EndEvent_Auditoria" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_Monitor">
      <bpmndi:BPMNShape id="Participant_Gestao_di" bpmnElement="Participant_Gestao" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="1340" height="440" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HITL_di" bpmnElement="Lane_HITL" isHorizontal="true">
        <dc:Bounds x="150" y="300" width="1310" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Monitor_di" bpmnElement="Lane_Monitor" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="1310" height="220" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_NovoLog_di" bpmnElement="StartEvent_NovoLog">
        <dc:Bounds x="200" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="180" y="185" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ingerir_di" bpmnElement="Task_Ingerir">
        <dc:Bounds x="280" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Calcular_di" bpmnElement="Task_Calcular">
        <dc:Bounds x="420" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Anomalia_di" bpmnElement="Gateway_Anomalia" isMarkerVisible="true">
        <dc:Bounds x="565" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="561" y="90" width="59" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Descartar_di" bpmnElement="Task_Descartar">
        <dc:Bounds x="630" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SemAcao_di" bpmnElement="EndEvent_SemAcao">
        <dc:Bounds x="760" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="739" y="188" width="74" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Severidade_di" bpmnElement="Gateway_Severidade" isMarkerVisible="true">
        <dc:Bounds x="800" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="793" y="97" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EmitirAlerta_di" bpmnElement="Task_EmitirAlerta">
        <dc:Bounds x="920" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AvaliarContexto_di" bpmnElement="Task_AvaliarContexto">
        <dc:Bounds x="775" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Aprovar_di" bpmnElement="Gateway_Aprovar" isMarkerVisible="true">
        <dc:Bounds x="925" y="375" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="877" y="355" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Autorizar_di" bpmnElement="Task_Autorizar">
        <dc:Bounds x="1050" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegistrarFalso_di" bpmnElement="Task_RegistrarFalso">
        <dc:Bounds x="1050" y="430" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GravarAuditoria_di" bpmnElement="Task_GravarAuditoria">
        <dc:Bounds x="1220" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Auditoria_di" bpmnElement="EndEvent_Auditoria">
        <dc:Bounds x="1360" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1335" y="185" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="236" y="160" />
        <di:waypoint x="280" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="380" y="160" />
        <di:waypoint x="420" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="520" y="160" />
        <di:waypoint x="565" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NaoRuido_di" bpmnElement="Flow_NaoRuido">
        <di:waypoint x="590" y="185" />
        <di:waypoint x="590" y="250" />
        <di:waypoint x="630" y="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="595" y="215" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FimRuido_di" bpmnElement="Flow_FimRuido">
        <di:waypoint x="730" y="250" />
        <di:waypoint x="760" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SimAnomalia_di" bpmnElement="Flow_SimAnomalia">
        <di:waypoint x="615" y="160" />
        <di:waypoint x="800" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="698" y="142" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BaixaMedia_di" bpmnElement="Flow_BaixaMedia">
        <di:waypoint x="850" y="160" />
        <di:waypoint x="920" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="846" y="142" width="67" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AltaAmbiguo_di" bpmnElement="Flow_AltaAmbiguo">
        <di:waypoint x="825" y="185" />
        <di:waypoint x="825" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="835" y="270" width="73" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ParaAprovar_di" bpmnElement="Flow_ParaAprovar">
        <di:waypoint x="875" y="400" />
        <di:waypoint x="925" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SimHITL_di" bpmnElement="Flow_SimHITL">
        <di:waypoint x="950" y="375" />
        <di:waypoint x="950" y="360" />
        <di:waypoint x="1050" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="975" y="343" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NaoHITL_di" bpmnElement="Flow_NaoHITL">
        <di:waypoint x="950" y="425" />
        <di:waypoint x="950" y="470" />
        <di:waypoint x="1050" y="470" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="975" y="452" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ParaAuditoria1_di" bpmnElement="Flow_ParaAuditoria1">
        <di:waypoint x="1020" y="160" />
        <di:waypoint x="1220" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ParaAuditoria2_di" bpmnElement="Flow_ParaAuditoria2">
        <di:waypoint x="1150" y="360" />
        <di:waypoint x="1180" y="360" />
        <di:waypoint x="1180" y="180" />
        <di:waypoint x="1220" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ParaAuditoria3_di" bpmnElement="Flow_ParaAuditoria3">
        <di:waypoint x="1150" y="470" />
        <di:waypoint x="1270" y="470" />
        <di:waypoint x="1270" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FimFinal_di" bpmnElement="Flow_FimFinal">
        <di:waypoint x="1320" y="160" />
        <di:waypoint x="1360" y="160" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
